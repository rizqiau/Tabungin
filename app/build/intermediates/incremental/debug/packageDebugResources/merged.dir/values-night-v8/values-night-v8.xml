<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Ones" parent="Theme.MaterialComponents.DayNight">
        <item name="colorPrimary">@color/primaryColorDark</item>
        <item name="colorPrimaryVariant">@color/primaryColorVariantDark</item>
        <item name="android:windowBackground">@color/backgroundColorDark</item>
        <item name="colorSurface">@color/surfaceColorDark</item>
        <item name="colorError">@color/errorColorDark</item>
        <item name="colorOnPrimary">@color/backgroundColorDark</item>
        <item name="colorOnSurface">@color/textPrimaryDark</item>
        <item name="colorOnBackground">@color/textSecondaryDark</item>

        
        <item name="android:textColor">@color/textPrimaryDark</item>
        <item name="android:textColorSecondary">@color/textSecondaryDark</item>
        <item name="dividerColor">@color/dividerColorDark</item>
        <item name="textInputStyle">@style/Widget.Material3.TextInputLayout.OutlinedBox</item>
    </style>
    <style name="Theme.Ones.Splash" parent="Theme.SplashScreen">
        
        <item name="windowSplashScreenBackground">@color/white</item>
        
        <item name="windowSplashScreenAnimatedIcon">@drawable/ic_logo</item>
        
        <item name="postSplashScreenTheme">@style/Theme.Ones</item>
    </style>
</resources>